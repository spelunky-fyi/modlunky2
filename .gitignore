# Rust build output (Cargo workspace target dir at repo root).
/target/

# Node dependencies + Vite build output for the Tauri frontend.
node_modules/

# scripts/build-release.mjs output.
/release/

# Bundled native DLLs consumed by ml2_assets' vorbis pipeline live under
# dist/ and are the only files that should ever appear there.
dist/**
!dist/libogg.dll
!dist/libvorbis.dll

# VS Code: check in only the shared extension recommendations + settings.
.vscode/*
!/.vscode/extensions.json
!/.vscode/settings.json
